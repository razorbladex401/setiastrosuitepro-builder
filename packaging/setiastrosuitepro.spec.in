Name:           setiastrosuitepro
Version:        @VERSION@
Release:        @RELEASE@%{?dist}
Summary:        Advanced astrophotography toolkit (wrapper package)

# This package bundles a Python virtualenv containing many prebuilt binary
# wheels. Running the default RPM debug/strip pipeline against those vendor
# binaries causes build failures (missing build-id, illformed ELF warnings).
%global debug_package %{nil}
%global __os_install_post %{nil}
%global _missing_build_ids_terminate_build 0
%global __requires_exclude_from ^/opt/%{name}/venv/.*$
%global __provides_exclude_from ^/opt/%{name}/venv/.*$

License:        GPL-3.0-only
URL:            https://github.com/setiastro/setiastrosuitepro
Source0:        %{name}-%{version}.tar.gz
Source1:        setiastrosuitepro-launcher.sh
Source2:        setiastrosuitepro.desktop

BuildArch:      x86_64
BuildRequires:  bash
BuildRequires:  python3
BuildRequires:  python3-devel
BuildRequires:  python3-pip
BuildRequires:  desktop-file-utils
BuildRequires:  hicolor-icon-theme

Requires:       bash
Requires:       python3
Requires(post): desktop-file-utils
Requires(postun): desktop-file-utils
Requires(post): hicolor-icon-theme
Requires(postun): hicolor-icon-theme

%description
This package wraps Seti Astro Suite Pro and installs it into a private Python
virtual environment under /opt/setiastrosuitepro.

The build pulls Python dependencies with pip during RPM build time.
Internet access is required unless you pre-populate a wheel cache.

%prep
%setup -q

%build
# No compile step here; pip/venv install is performed in %%install.

%install
rm -rf %{buildroot}

python3 -m venv --copies venv-build
venv-build/bin/pip install --upgrade pip setuptools wheel
venv-build/bin/pip install .

install -d %{buildroot}/opt/%{name}
cp -a venv-build %{buildroot}/opt/%{name}/venv

# Entry-point scripts created inside the build-time virtualenv contain absolute
# shebangs into the temporary build directory. Rewrite them to the final path.
while IFS= read -r -d '' file; do
  if head -n1 "$file" | grep -q '^#!'; then
    sed -i '1 s|^#!.*/venv-build/bin/python3$|#!/opt/%{name}/venv/bin/python3|' "$file"
  fi
done < <(find %{buildroot}/opt/%{name}/venv/bin -maxdepth 1 -type f -print0)

install -Dpm0755 %{SOURCE1} %{buildroot}%{_bindir}/%{name}
install -Dpm0644 %{SOURCE2} %{buildroot}%{_datadir}/applications/%{name}.desktop
install -Dpm0644 src/setiastro/images/astrosuitepro.png %{buildroot}%{_datadir}/icons/hicolor/256x256/apps/%{name}.png

%post
if [ -x /usr/bin/update-desktop-database ]; then
  /usr/bin/update-desktop-database -q %{_datadir}/applications || :
fi
if [ -x /usr/bin/gtk-update-icon-cache ]; then
  /usr/bin/gtk-update-icon-cache -q -t -f %{_datadir}/icons/hicolor || :
fi

%postun
if [ $1 -eq 0 ]; then
  if [ -x /usr/bin/update-desktop-database ]; then
    /usr/bin/update-desktop-database -q %{_datadir}/applications || :
  fi
  if [ -x /usr/bin/gtk-update-icon-cache ]; then
    /usr/bin/gtk-update-icon-cache -q -t -f %{_datadir}/icons/hicolor || :
  fi
fi

%files
%license LICENSE license.txt
%doc README.md
%{_bindir}/%{name}
%{_datadir}/applications/%{name}.desktop
%{_datadir}/icons/hicolor/256x256/apps/%{name}.png
/opt/%{name}

%changelog
* Thu Apr 23 2026 Wrapper Maintainer <maintainer@example.com> - @VERSION@-@RELEASE@
- Initial wrapper RPM packaging
