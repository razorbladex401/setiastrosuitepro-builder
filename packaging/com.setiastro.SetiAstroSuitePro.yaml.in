app-id: com.setiastro.SetiAstroSuitePro
runtime: org.freedesktop.Platform
runtime-version: '24.08'
sdk: org.freedesktop.Sdk
command: setiastrosuitepro
finish-args:
  - --share=ipc
  - --share=network
  - --socket=fallback-x11
  - --socket=wayland
  - --device=dri
  - --filesystem=home
cleanup:
  - /include
  - /lib/pkgconfig
  - /share/pkgconfig
  - /share/aclocal
  - /man
  - /share/man
  - '*.a'
modules:
  - name: krb5
    subdir: src
    buildsystem: autotools
    config-opts:
      - --localstatedir=/var/lib
      - --sbindir=/app/bin
      - --disable-static
      - --disable-rpath
    cleanup:
      - /bin
      - /include
      - /lib/pkgconfig
      - /share
    sources:
      - type: archive
        url: https://web.mit.edu/kerberos/dist/krb5/1.21/krb5-1.21.3.tar.gz
        sha256: b7a4cd5ead67fb08b980b21abd150ff7217e85ea320c9ed0c6dadd304840ad35

  - name: setiastrosuitepro
    buildsystem: simple
    build-options:
      build-args:
        - --share=network
    build-commands:
      - python3 -c "import sys; assert sys.version_info[:2] == (3, 12), f'Flatpak SDK Python must be 3.12, found {sys.version_info[0]}.{sys.version_info[1]}'"
      - sed -i 's|py_cmd + \["-m", "venv", str(p\["venv"\])\]|py_cmd + ["-m", "venv", "--copies", str(p["venv"])]|' src/setiastro/saspro/runtime_torch.py
      - python3 -m venv --copies /app/venv
      - /app/venv/bin/pip install --upgrade pip setuptools wheel Pillow
      - /app/venv/bin/pip install .
      - /app/venv/bin/python3 -c "from PIL import Image; img=Image.open('src/setiastro/images/astrosuitepro.png').resize((512,512), Image.LANCZOS); img.save('icon_512.png')"
      - install -Dm755 setiastrosuitepro-flatpak-launcher.sh /app/bin/setiastrosuitepro
      - install -Dm644 setiastrosuitepro.desktop /app/share/applications/com.setiastro.SetiAstroSuitePro.desktop
      - sed -i 's|^Icon=.*|Icon=com.setiastro.SetiAstroSuitePro|' /app/share/applications/com.setiastro.SetiAstroSuitePro.desktop
      - install -Dm644 icon_512.png /app/share/icons/hicolor/512x512/apps/com.setiastro.SetiAstroSuitePro.png
    sources:
      - type: archive
        path: @SOURCE_ARCHIVE_PATH@
      - type: file
        path: @LAUNCHER_PATH@
      - type: file
        path: @DESKTOP_PATH@
